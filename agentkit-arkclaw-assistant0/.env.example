# Copy this file to `.env` and fill in your Volcengine AK/SK.
# VeADK loads `.env` from the current working directory. This file is for
# running the agent locally — it is NOT uploaded to the runtime on
# `agentkit deploy`.

# --- Volcengine credentials ---
# Set your AK/SK to run the agent locally — the model credential is derived from
# them automatically. On the AgentKit cloud runtime this is provided for you, so
# there is nothing else to configure.
VOLCENGINE_ACCESS_KEY=
VOLCENGINE_SECRET_KEY=
# VOLCENGINE_REGION=cn-beijing

# --- Agent reasoning model (optional) ---
# You normally do NOT set these — the model credential comes from AK/SK above.
# Uncomment to pin a specific model/provider locally. Do NOT leave a placeholder
# value: a non-empty MODEL_AGENT_API_KEY overrides the automatic credential and
# will fail auth.
# MODEL_AGENT_PROVIDER=openai
# MODEL_AGENT_NAME=doubao-seed-1-6-250615
# MODEL_AGENT_API_BASE=https://ark.cn-beijing.volces.com/api/v3/
# MODEL_AGENT_API_KEY=
